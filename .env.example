# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# OpenAI model used for translation (optional, default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# OpenAI TTS model (optional, default: gpt-4o-mini-tts)
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# OpenAI TTS voice (optional, default: marin)
OPENAI_TTS_VOICE=marin
